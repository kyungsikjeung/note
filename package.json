{
  "name": "ksnote",
  "version": "0.1.0",
  "private": true,
  "description": "A local-first smart workspace for notes, code, tables, images, and diagrams.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:electron": "wait-on http://127.0.0.1:5173 && nodemon --watch electron --ext cjs --signal SIGTERM --exec \"electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "desktop": "electron ."
  },
  "dependencies": {
    "@tiptap/extension-code-block-lowlight": "^3.27.4",
    "@tiptap/extension-color": "^3.27.4",
    "@tiptap/extension-drag-handle-react": "^3.27.4",
    "@tiptap/extension-highlight": "^3.27.4",
    "@tiptap/extension-image": "^3.27.4",
    "@tiptap/extension-link": "^3.27.4",
    "@tiptap/extension-table": "^3.27.4",
    "@tiptap/extension-table-cell": "^3.27.4",
    "@tiptap/extension-table-header": "^3.27.4",
    "@tiptap/extension-table-row": "^3.27.4",
    "@tiptap/extension-task-item": "^3.27.4",
    "@tiptap/extension-task-list": "^3.27.4",
    "@tiptap/extension-text-align": "^3.27.4",
    "@tiptap/extension-text-style": "^3.27.4",
    "@tiptap/extension-underline": "^3.27.4",
    "@tiptap/pm": "^3.27.4",
    "@tiptap/react": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "@vitejs/plugin-react": "latest",
    "docx": "^9.7.1",
    "highlight.js": "latest",
    "lowlight": "^3.3.0",
    "lucide-react": "latest",
    "marked": "latest",
    "mermaid": "latest",
    "react": "latest",
    "react-dom": "latest",
    "sql.js": "^1.14.1",
    "tesseract.js": "^7.0.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "concurrently": "latest",
    "electron": "latest",
    "nodemon": "^3.1.14",
    "wait-on": "latest"
  }
}
